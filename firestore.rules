rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio']);

      function isValidUser(data) {
        return data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 50
            && data.uid == request.auth.uid;
      }
    }

    // --- Posts ---
    match /posts/{postId} {
      // Cho phép mọi người xem bài viết công khai để tăng tính tương tác
      allow read: if true; 
      
      allow create: if isSignedIn() && isValidPost(incoming()) && incoming().authorId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        // Chỉ chủ bài viết mới được sửa nội dung
        (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content']) && isValidPost(incoming())) ||
        // Cho phép tăng lượt tương tác (likes) một cách có kiểm soát
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && incoming().likes == existing().likes + 1)
      );
      
      allow delete: if isSignedIn() && isOwner(existing().authorId);

      function isValidPost(data) {
        return data.content is string && data.content.size() > 0 && data.content.size() <= 2000
            && data.authorId is string && data.authorName is string
            && data.createdAt == request.time;
      }
    }
  }
}
