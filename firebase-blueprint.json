{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with points and medals info.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "uid": { "type": "string" },
        "medalsCount": { "type": "number" },
        "points": { "type": "number" }
      },
      "required": ["uid"]
    },
    "CourseProgress": {
      "title": "Course Progress",
      "description": "Tracks a user's progress in a specific course.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "completedLessonIds": { "type": "array" },
        "isCompleted": { "type": "boolean" },
        "lastAccessed": { "type": "string", "format": "date-time" }
      }
    },
    "Medal": {
      "title": "Medal Achievement",
      "description": "Medals earned by users for completing courses.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "medalName": { "type": "string" },
        "earnedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile collection."
    },
    "userProgress/{progressId}": {
      "schema": "CourseProgress",
      "description": "User course progress tracking."
    },
    "medals/{medalId}": {
      "schema": "Medal",
      "description": "Collection of medals awarded to users."
    }
  }
}
