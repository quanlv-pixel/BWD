{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public user profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["displayName", "uid"]
    },
    "Post": {
      "title": "Community Post",
      "description": "A post shared in the self-study community.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "authorName", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile collection."
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Community posts collection."
    }
  }
}
